{
  "manifest_version": 3,
  "name": "Tab Dedup — 重复 Tab 管理",
  "version": "1.1.0",
  "description": "检测当前窗口中的同域名 Tab，保留当前标签页并询问是否关闭其他 Tab，默认 1 秒后自动执行。",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Tab Dedup",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "background": {
    "service_worker": "src/background/service-worker.js"
  },
  "options_ui": {
    "page": "src/options/options.html",
    "open_in_tab": true
  },
  "permissions": [
    "tabs",
    "storage",
    "scripting",
    "notifications",
    "webNavigation"
  ],
  "host_permissions": [
    "<all_urls>"
  ]
}
