{
  "manifest_version": 3,
  "name": "Tab Dedup — 重复 Tab 管理",
  "version": "1.2.0",
  "description": "检测当前窗口中的重复 Tab，提供清理、整理到分组或忽略三选项，默认 5 秒后自动清理。",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Tab Dedup — 单击快捷设置，双击扫描重复 Tab",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "background": {
    "service_worker": "src/background/service-worker.js"
  },
  "options_ui": {
    "page": "src/options/options.html",
    "open_in_tab": true
  },
  "permissions": [
    "tabs",
    "tabGroups",
    "storage",
    "scripting",
    "notifications",
    "webNavigation"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["src/content/tab-origin.js"],
      "run_at": "document_start"
    }
  ]
}
